# .gitignore for ros2-brain-agent

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
ENV/
env/
.venv/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# ROS2
install/
log/
.colcon_install_layout

# Memory data (keep structure, ignore content)
memory/sessions/*/
!memory/sessions/.gitkeep
memory/global/user_facts.json

# Keep template files
!memory/global/user_facts.json.template

# Logs
*.log
logs/

# Test coverage
.coverage
htmlcov/
.pytest_cache/

# Environment variables
.env
.env.local

# OS
.DS_Store
Thumbs.db

# Docker
.docker/

# Temporary test files
/tmp/
*.tmp
